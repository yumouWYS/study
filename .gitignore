# ===================== 基础忽略（保留你的原有规则，修复写法） =====================
# Visual Studio 2015+ user specific files
.vs/
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
.vsconfig

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# ===================== 修复核心：UE5 缓存目录（所有层级） =====================
# 二进制文件（所有层级的 Binaries，包括项目/插件下）
Binaries/
Plugins/**/Binaries/

# 构建产物（所有层级）
Build/
!Build/*/PakBlacklist*.txt  
# 白名单：保留 PakBlacklist 文件
!Build/**/*.ico             
# 白名单：保留图标文件

# 编辑器配置/缓存
Saved/
Intermediate/
Plugins/**/Intermediate/
DerivedDataCache/
Plugins/**/DerivedDataCache/

# UE5 特有缓存文件
*.ushadercache
*.assetregistrycache
*.uexp
*.ubulk
*.uptnl
*.ini.save
*.log
*.bak
*.tmp
*.sav
*.autosave
*.manifest
*.crash
*.mdb
*.ipch

# ===================== 多项目仓库额外忽略 =====================
# 每个UE5项目的本地配置（避免多项目冲突）
*/Config/DefaultEditor*.ini
*/Config/DefaultGameUserSettings.ini
*/Saved/Config/
*/Intermediate/ProjectFiles/

# 临时测试文件/大文件
*.zip
*.rar
*.7z
*.iso
*.mp4
*.mov
*.wav
*.mp3